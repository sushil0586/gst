SECRET_KEY=change-me
JWT_SIGNING_KEY=change-me-jwt-signing-key-with-at-least-32-characters
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
TIME_ZONE=Asia/Kolkata

POSTGRES_DB=gst_compliance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=0
DB_CONN_HEALTH_CHECKS=False

USE_SQLITE_FALLBACK=False

MEDIA_STORAGE_BACKEND=filesystem
MEDIA_URL=/media/
# Set MEDIA_STORAGE_BACKEND=s3 for shared object storage in scaled environments.
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_CUSTOM_DOMAIN=
AWS_DEFAULT_ACL=
AWS_QUERYSTRING_AUTH=False
AWS_S3_FILE_OVERWRITE=False
AWS_LOCATION=media

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=False
PAGE_SIZE=20
MAX_IMPORT_UPLOAD_BYTES=10485760
PERFORMANCE_HEADERS_ENABLED=True
PERFORMANCE_SLOW_REQUEST_MS=1200
PERFORMANCE_LOG_LEVEL=INFO
CACHE_BACKEND=locmem
CACHE_LOCATION=gst-compliance
CACHE_REDIS_URL=redis://127.0.0.1:6379/0
CACHE_KEY_PREFIX=gst-compliance
CACHE_DEFAULT_TIMEOUT=60
CACHE_WORKSPACE_CONTEXT_SECONDS=60
CACHE_DASHBOARD_SUMMARY_SECONDS=30
CACHE_CLOSE_MANAGER_SECONDS=30
CACHE_RETURN_READINESS_SECONDS=30
IMPORT_ALLOW_EDIT_AFTER_RECONCILIATION=True
IMPORT_ALLOW_DISCARD_AFTER_PROCESSING=True
IMPORT_ALLOW_MUTATION_AFTER_RETURN_APPROVAL=False
IMPORT_ALLOW_MUTATION_AFTER_FILING=False
IMPORT_REQUIRE_RECONCILIATION_RERUN_AFTER_SOURCE_CHANGE=True
IMPORT_BLOCK_RETURN_APPROVAL_ON_STALE_RECONCILIATION=True
IMPORT_BLOCK_RETURN_FILING_ON_STALE_RECONCILIATION=True
IMPORT_REPLACEMENT_UPLOAD_CREATES_NEW_VERSION=True

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Demo login after running `python manage.py seed_demo_data`
# Email: demo_admin@example.com
# Password: demo12345

REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=True
CELERY_STRICT_PRODUCTION_ASYNC=False
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_TASK_ACKS_LATE=True
CELERY_WORKER_PREFETCH_MULTIPLIER=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=200
CELERY_WORKER_SEND_TASK_EVENTS=False
CELERY_IMPORTS_QUEUE=imports
CELERY_RECONCILIATION_QUEUE=reconciliation
CELERY_FILINGS_QUEUE=filings
CELERY_SCHEDULED_QUEUE=scheduled

# Digest email delivery
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=GST Compliance <no-reply@gstcompliance.local>
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10

# Production transport and browser security defaults
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
X_FRAME_OPTIONS=DENY
USE_X_FORWARDED_PROTO=False
ENABLE_API_DOCS=True

# API throttling
THROTTLE_ANON_RATE=120/hour
THROTTLE_USER_RATE=1000/hour
THROTTLE_LOGIN_RATE=10/minute
THROTTLE_REGISTRATION_RATE=5/hour
THROTTLE_SESSION_RATE=120/minute
THROTTLE_PROVIDER_OTP_REQUEST_RATE=5/10minute
THROTTLE_PROVIDER_OTP_VERIFY_RATE=10/10minute
THROTTLE_SENSITIVE_EXPORT_RATE=20/hour

# Sensitive payload retention
SECURITY_RETENTION_ENABLED=False
SECURITY_RETENTION_AUDIT_DAYS=180
SECURITY_RETENTION_FILING_DAYS=90
SECURITY_RETENTION_PROVIDER_AUTH_DAYS=30
SECURITY_RETENTION_IMPORT_DAYS=30
SECURITY_RETENTION_SCHEDULE_HOUR=2
SECURITY_RETENTION_SCHEDULE_MINUTE=0
SECURITY_LOG_LEVEL=INFO
SECURITY_LOG_FILE=

# Scheduled close-manager digests
CLOSE_MANAGER_DIGEST_ENABLED=False
CLOSE_MANAGER_DIGEST_DELIVERY_CHANNEL=in_app
CLOSE_MANAGER_DIGEST_RECIPIENT_ROLES=owner,admin,manager
CLOSE_MANAGER_DIGEST_SCHEDULE_HOUR=9
CLOSE_MANAGER_DIGEST_SCHEDULE_MINUTE=0

# Scheduled remediation follow-up reminders
REMEDIATION_FOLLOW_UP_AUTOMATION_ENABLED=False
REMEDIATION_FOLLOW_UP_DELIVERY_CHANNEL=in_app
REMEDIATION_FOLLOW_UP_SCHEDULE_MINUTE=15
REMEDIATION_AUTO_ESCALATION_ENABLED=True
REMEDIATION_AUTO_ESCALATION_DELAY_HOURS=24

# WhiteBooks sandbox / production integration
WHITEBOOKS_SANDBOX_MODE=True
WHITEBOOKS_BASE_URL=https://apisandbox.whitebooks.in
WHITEBOOKS_API_KEY=
WHITEBOOKS_API_SECRET=
WHITEBOOKS_USERNAME=
WHITEBOOKS_PASSWORD=
WHITEBOOKS_CONTACT_EMAIL=
# Optional fallback only; prefer storing the taxpayer GST username per GSTIN in the database.
WHITEBOOKS_GST_USERNAME=
# Optional fallback only; filing/auth flows should derive this from the GSTIN where possible.
WHITEBOOKS_STATE_CODE=
WHITEBOOKS_IP_ADDRESS=127.0.0.1
WHITEBOOKS_TIMEOUT_SECONDS=30
# Keep True in production. Set False only for local sandbox debugging if Python SSL trust fails.
WHITEBOOKS_SSL_VERIFY=True
# Optional custom CA bundle path for WhiteBooks TLS validation.
WHITEBOOKS_CA_BUNDLE=
WHITEBOOKS_ENABLE_GSTR1_SAVE_LIVE=False
WHITEBOOKS_ENABLE_GSTR1_PROCEED_LIVE=False
WHITEBOOKS_ENABLE_GSTR1_FILE_LIVE=False
WHITEBOOKS_ENABLE_GSTR3B_SAVE_LIVE=False
WHITEBOOKS_ENABLE_GSTR3B_OFFSET_LIVE=False
WHITEBOOKS_ENABLE_GSTR3B_FILE_LIVE=False
FILING_ENFORCE_TENANT_ROLLOUT=False
FILING_ENFORCE_MAKER_CHECKER=False
FILING_ALERT_EMAIL_ENABLED=False
FILING_SUPPORT_RECOVERY_ROLES=owner,admin,manager,reviewer,senior_ca
FILING_DEFAULT_ALERT_RECIPIENT_ROLES=reviewer,manager,admin
